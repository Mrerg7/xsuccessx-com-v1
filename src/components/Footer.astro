---
import { SITE, ACQUISITION_MAILTO } from '../config/site';

const currentYear = new Date().getFullYear();
---

<footer class="relative z-10 border-t border-white/10 bg-void">
  <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6 sm:py-16">
    <!-- Domain Acquisition CTA -->
    <div
      class="relative mb-12 overflow-hidden rounded-3xl border border-x-blue/25 bg-gradient-to-br from-surface via-void to-x-blue/10 p-6 sm:p-10 md:p-12"
    >
      <div
        class="pointer-events-none absolute -top-24 -right-24 h-64 w-64 rounded-full bg-x-blue/10 blur-3xl"
        aria-hidden="true"
      >
      </div>
      <div
        class="pointer-events-none absolute -bottom-24 -left-24 h-64 w-64 rounded-full bg-emerald-glow/10 blur-3xl"
        aria-hidden="true"
      >
      </div>

      <div class="relative z-10 grid items-center gap-8 lg:grid-cols-[1.2fr_0.8fr] lg:gap-10">
        <div>
          <p class="mb-4 text-xs font-extrabold tracking-[3px] text-x-blue uppercase">
            Domain Available for Acquisition
          </p>
          <h2 class="font-display mb-4 text-2xl tracking-tight sm:text-3xl md:text-4xl">
            xsuccessx.com — A Category-Defining Digital Asset
          </h2>
          <p class="max-w-xl leading-relaxed text-muted">
            Positioned at the intersection of X.com creator education, social media mastery, and the
            creator economy, this premium .com domain is a rare strategic asset. Serious buyers may
            inquire for pricing, transfer logistics, and escrow options.
          </p>
        </div>

        <div
          class="rounded-2xl border border-white/10 p-6 sm:p-8"
          style="background: rgba(10, 10, 10, 0.88); backdrop-filter: blur(22px);"
        >
          <p class="mb-2 text-xs font-semibold tracking-[2px] text-muted uppercase">
            Acquisition Contact
          </p>
          <a
            href={`mailto:${SITE.email}`}
            class="font-display block text-xl break-all text-foreground transition-colors hover:text-x-blue sm:text-2xl md:text-3xl"
          >
            {SITE.email}
          </a>
          <a
            href={ACQUISITION_MAILTO}
            class="mt-6 inline-flex w-full min-h-12 items-center justify-center gap-x-3 rounded-2xl bg-gradient-to-r from-x-blue to-[#0a84ff] px-6 py-4 font-extrabold text-white transition-all hover:brightness-110"
          >
            <span>Inquire About Acquisition</span>
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 12h14M12 5l7 7-7 7"></path>
            </svg>
          </a>
          <p class="mt-4 text-center text-[11px] tracking-wide text-muted">
            Confidential inquiries &bull; Response within 24 hours
          </p>
        </div>
      </div>
    </div>

    <!-- Disclaimer -->
    <p class="mb-10 max-w-4xl text-xs leading-relaxed text-muted">
      This website is for demonstration and informational purposes only. It does not constitute an
      offer of services, a commitment to deploy, or a guarantee of outcomes. All statistics,
      projections, and references to specific technologies are based on publicly available
      information as of {SITE.datePublished} and are subject to change.
    </p>

    <!-- Bottom bar -->
    <div
      class="flex flex-col items-center justify-between gap-y-4 border-t border-white/10 pt-8 text-xs text-muted md:flex-row"
    >
      <div>&copy; {currentYear} {SITE.name}. All rights reserved.</div>
      <div class="flex flex-wrap items-center justify-center gap-x-5 gap-y-2">
        <a
          href="https://x.com/XCreators"
          target="_blank"
          rel="noopener noreferrer"
          class="transition-colors hover:text-foreground"
        >
          Follow @XCreators
        </a>
        <a
          href="https://help.x.com/en/using-x/live-studio"
          target="_blank"
          rel="noopener noreferrer"
          class="transition-colors hover:text-foreground"
        >
          Live Studio Help
        </a>
        <span>Premium domain listing by owner</span>
      </div>
    </div>
  </div>
</footer>
